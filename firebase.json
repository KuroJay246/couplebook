{
  "hosting": {
    "public": "app-v2/dist",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.app-v2.rules",
      "**/.*",
      "**/node_modules/**",
      "**/*.map",
      "**/*.local",
      "**/.env*",
      ".local-backups/**",
      ".local-migration-packages/**",
      "app-v2/local-migration-packages/**",
      "app-v2/src/**",
      "app-v2/scripts/**",
      "app-v2/public/**",
      "server.js",
      "project_audit.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "cleanUrls": false,
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|mp4|mov|webm)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=86400"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
